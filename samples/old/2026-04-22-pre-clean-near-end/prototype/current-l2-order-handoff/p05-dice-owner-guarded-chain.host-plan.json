{
  "schema_version": "current-l2-host-plan-v0",
  "predicate_rules": [
    {
      "site": "option-admit",
      "op": "handoff_dice_authority",
      "option_ref": "current_owner",
      "verdict": "unsatisfied"
    },
    {
      "site": "option-admit",
      "op": "handoff_dice_authority",
      "option_ref": "delegated_owner",
      "verdict": "satisfied"
    },
    {
      "site": "request-require",
      "op": "handoff_dice_authority",
      "mode": "via",
      "chain_ref": "dice_owner_ref",
      "option_ref": "delegated_owner",
      "verdict": "satisfied"
    },
    {
      "site": "request-ensure",
      "op": "handoff_dice_authority",
      "mode": "via",
      "chain_ref": "dice_owner_ref",
      "option_ref": "delegated_owner",
      "verdict": "satisfied"
    }
  ],
  "effect_rules": [
    {
      "op": "handoff_dice_authority",
      "mode": "via",
      "chain_ref": "dice_owner_ref",
      "selected_option_ref": "delegated_owner",
      "selected_target": "dice_state",
      "verdict": {
        "kind": "success",
        "commit": {
          "mutations": [
            {
              "kind": "append-record",
              "target": "dice_state",
              "record": "handoff_dice_authority@delegated_owner"
            },
            {
              "kind": "append-record",
              "target": "dice_guard_debug_output",
              "record": "guarded_chain: delegated_owner -> player_b"
            }
          ]
        }
      }
    }
  ],
  "trace_expectation_override": {}
}
